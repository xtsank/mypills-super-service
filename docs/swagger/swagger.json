{
    "swagger": "2.0",
    "info": {
        "contact": {}
    },
    "paths": {
        "/auth/login": {
            "post": {
                "description": "Проверяет логин и пароль, возвращая данные пользователя при успешной авторизации",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "auth"
                ],
                "summary": "Авторизация пользователя",
                "parameters": [
                    {
                        "description": "Данные пользователя (JSON)",
                        "name": "input",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/LoginUserDto"
                        }
                    }
                ],
                "responses": {}
            }
        },
        "/auth/register": {
            "post": {
                "description": "Создает аккаунт, сохраняя данные о весе, возрасте и аллергиях для подбора лекарств",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "auth"
                ],
                "summary": "Регистрация нового пользователя",
                "parameters": [
                    {
                        "description": "Данные пользователя (JSON)",
                        "name": "input",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/CreateUserDto"
                        }
                    }
                ],
                "responses": {}
            }
        }
    },
    "definitions": {
        "CreateUserDto": {
            "type": "object",
            "required": [
                "age",
                "login",
                "password",
                "weight"
            ],
            "properties": {
                "age": {
                    "type": "integer"
                },
                "allergies": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "illnesses": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "is_driver": {
                    "type": "boolean"
                },
                "is_pregnant": {
                    "type": "boolean"
                },
                "login": {
                    "type": "string",
                    "minLength": 8
                },
                "password": {
                    "type": "string",
                    "minLength": 8
                },
                "sex": {
                    "type": "boolean"
                },
                "weight": {
                    "type": "integer"
                }
            }
        },
        "LoginUserDto": {
            "type": "object",
            "required": [
                "login",
                "password"
            ],
            "properties": {
                "login": {
                    "type": "string"
                },
                "password": {
                    "type": "string"
                }
            }
        }
    }
}